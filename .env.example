# ─── OmWhisper Build Environment Variables ────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# These are baked into the binary at compile time — never commit .env to git.
#
# Usage:
#   cp .env.example .env
#   # fill in values, then:
#   cargo tauri dev   (dev)
#   cargo tauri build (release)
# ──────────────────────────────────────────────────────────────────────────────


# ─── Aptabase — Anonymous Usage Analytics ─────────────────────────────────────
# Tracks feature usage (no audio or text is ever sent).
# Get your key: https://aptabase.com → New App → macOS/Windows
# Leave blank to disable analytics in dev builds.
APTABASE_APP_KEY=A-EU-XXXXXXXX


# ─── Sentry — Crash Reporting (Rust backend) ──────────────────────────────────
# Captures panics and errors from the Rust backend.
# Get your DSN: https://sentry.io → New Project → Rust
# Leave blank to disable crash reporting in dev builds.
SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/123456


# ─── Sentry — Crash Reporting (React frontend) ────────────────────────────────
# Captures unhandled JS errors from the React UI.
# Get your DSN: https://sentry.io → New Project → React
# Use a separate project from the Rust DSN above.
# Leave blank to disable frontend crash reporting.
VITE_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/123456


# ─── Resend — In-App Feedback Emails ──────────────────────────────────────────
# Powers the feedback form in Settings → About → Feedback.
# Emails are sent from feedback@omwhisper.in to your inbox.
# Get your key: https://resend.com → API Keys → Create API Key
# Also verify your sending domain (omwhisper.in) in Resend → Domains.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

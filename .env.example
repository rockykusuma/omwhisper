# ─── OmWhisper Build Environment Variables ────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# These are baked into the binary at compile time — never commit .env to git.
#
# Usage:
#   cp .env.example .env
#   # fill in values, then:
#   cargo tauri dev   (dev)
#   cargo tauri build (release)
# ──────────────────────────────────────────────────────────────────────────────


# ─── Aptabase — Anonymous Usage Analytics ─────────────────────────────────────
# Tracks feature usage (no audio or text is ever sent).
# Get your key: https://aptabase.com → New App → macOS/Windows
# Leave blank to disable analytics in dev builds.
APTABASE_APP_KEY=A-EU-XXXXXXXX


# ─── Sentry — Crash Reporting (Rust backend) ──────────────────────────────────
# Captures panics and errors from the Rust backend.
# Get your DSN: https://sentry.io → New Project → Rust
# Leave blank to disable crash reporting in dev builds.
SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/123456


# ─── Sentry — Crash Reporting (React frontend) ────────────────────────────────
# Captures unhandled JS errors from the React UI.
# Get your DSN: https://sentry.io → New Project → React
# Use a separate project from the Rust DSN above.
# Leave blank to disable frontend crash reporting.
VITE_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/123456


# ─── Resend — In-App Feedback Emails ──────────────────────────────────────────
# Powers the feedback form in Settings → About → Feedback.
# Emails are sent from feedback@omwhisper.in to your inbox.
# Get your key: https://resend.com → API Keys → Create API Key
# Also verify your sending domain (omwhisper.in) in Resend → Domains.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── macOS Code Signing ────────────────────────────────────────────────────────
# Required to build a signed, notarizable release DMG (bash scripts/build-release.sh).
# Find your identity: security find-identity -v -p codesigning | grep "Developer ID"
# Leave blank or omit for local dev — signing is not required.
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"


# ─── macOS Notarization ────────────────────────────────────────────────────────
# Required to notarize and staple the DMG locally (bash scripts/notarize.sh).
# Also used by GitHub Actions CI to notarize release builds automatically.
# All three vars must be set — notarization is skipped if any are missing.
#
# APPLE_ID
#   Your Apple Developer account email address.
#   Example: you@example.com
#
# APPLE_ID_PASSWORD
#   An app-specific password — NOT your regular Apple ID password.
#   Generate one at: appleid.apple.com → Sign-In and Security → App-Specific Passwords
#   Format: xxxx-xxxx-xxxx-xxxx  (dashes required)
#
# APPLE_TEAM_ID
#   Your 10-character Apple Developer Team ID.
#   Find it at: developer.apple.com/account → Membership Details → Team ID
APPLE_ID=you@example.com
APPLE_ID_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX
